{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "doom_loop": "ask",
        "bash": {
            "pip *": "deny",
            "uv*": "allow",
            "findstr*": "deny",
            "grep*": "deny",
            "rg*": "allow",
            "python *": "deny",
            "python3 *": "deny",
            "tofu *": "deny",
            "terraform *": "deny",
            "git push*": "deny",
            "git reset*": "deny",
            "git clean*": "deny",
            "git branch -D*": "deny",
            "git filter-branch*": "deny",
            "git reflog*": "deny",
            "git gc*": "deny",
            "git update-ref*": "deny",
            "git remote*": "deny"
        }
    },
    "lsp": {
        "terraform": {
            "disabled": true
        },
        "tofu-ls": {
            "command": ["tofu-ls", "serve"],
            "extensions": [".tf", ".tfvars"]
        }
    },
    "tools": {
        "todowrite": true,
        "todoread": true,
        "docs-mcp-server": true
    },
    "compaction": {
        "prune": false
    },
    "plugin": [
        "oh-my-opencode@latest",
        "@tarquinen/opencode-dcp@latest",
    ],
    "watcher": {
        "ignore": [
            "node_modules/**",
            "dist/**",
            ".git/**",
            "__pycache__",
            ".venv/**"
        ]
    },
    "provider": {
        "local-llama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp",
            "options": {
                "baseURL": "http://192.168.1.146:10000/v1"
            },
            "models": {
                "qwen": {
                    "name": "Qwen 3.5",
                }
            }
        },
        "anthropic": {
            "options": {
                "timeout": 600000,
                "setCacheKey": true
            }
        },
    }
}
